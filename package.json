{
  "name": "ai-writer",
  "version": "0.2.1",
  "description": "AI novel writer — Electron shell, data on D:/E: drive",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "electron .",
    "backend": "npm run dev --prefix backend",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.aiwriter.app",
    "productName": "AI Writer",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "renderer/**/*",
      "backend/**/*",
      "package.json"
    ],
    "asarUnpack": ["electron/**/*"],
    "win": {
      "target": ["nsis"]
    },
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.productivity"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
