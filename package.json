{
  "name": "ai-writer",
  "version": "1.0.1",
  "description": "AI novel writer — Electron shell, data on D:/E: drive",
  "author": "02heng",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "electron .",
    "backend": "npm run dev --prefix backend",
    "build-backend": "node scripts/build-backend.cjs",
    "pack": "npm run build-backend && electron-builder --dir",
    "dist": "npm run build-backend && electron-builder --publish never"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.aiwriter.app",
    "productName": "AI Writer",
    "directories": {
      "output": "release"
    },
    "files": ["electron/**/*", "renderer/**/*", "package.json"],
    "extraResources": [
      {
        "from": "backend/dist/aiwriter-backend",
        "to": "backend-bin"
      }
    ],
    "asarUnpack": ["electron/**/*"],
    "win": {
      "target": ["nsis"]
    },
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.productivity"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
